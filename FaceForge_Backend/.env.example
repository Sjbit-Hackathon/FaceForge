# ============================================================
# FaceForge Backend — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your own values.
# NEVER commit a .env file or real credentials to the repository.
# If you accidentally commit secrets, rotate them immediately
# (see README.md § "Rotating credentials").
# ============================================================

APP_NAME=FaceForge API
ENVIRONMENT=development
API_PREFIX=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-long-random-secret-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Hugging Face — https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=your-huggingface-api-token
HF_FLUX_MODEL=black-forest-labs/FLUX.1-schnell
HF_CODEFORMER_MODEL=sczhou/CodeFormer
HF_REALESRGAN_MODEL=ai-forever/Real-ESRGAN
HF_INPAINTING_MODEL=stabilityai/stable-diffusion-2-inpainting
HF_TIMEOUT_SECONDS=120

# Supabase — https://app.supabase.com/project/<your-project>/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_REPORTS_BUCKET=faceforge-reports
SIGNED_URL_TTL_SECONDS=3600
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key